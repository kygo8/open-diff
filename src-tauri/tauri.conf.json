{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenDiff",
  "version": "1.0.1",
  "identifier": "io.github.kygo8.open-diff",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenDiff",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "publisher": "Open Diff Contributors",
    "homepage": "https://github.com/kygo8/open-diff",
    "icon": ["icons/icon.ico"],
    "license": "Apache-2.0",
    "copyright": "Copyright (c) 2026 Open Diff Contributors",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": {
        "upgradeCode": "90ffd755-2be3-5b35-8809-0f6022d8f999",
        "language": "en-US"
      }
    }
  }
}
